{
  "name": "kbc-church-app",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22 <23"
  },
  "scripts": {
    "dev": "cross-env NODE_ENV=development tsx server/index.ts",
    "build": "vite build && esbuild server/index.ts server/migrate.ts server/bootstrapAdmin.ts server/seedCli.ts --platform=node --packages=external --bundle --format=esm --outdir=dist && node scripts/build-docs-content.mjs",
    "start": "cross-env NODE_ENV=production node dist/index.js",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "node dist/migrate.js",
    "db:push": "drizzle-kit push",
    "db:bootstrap-admin": "node dist/bootstrapAdmin.js",
    "db:seed:baseline": "node dist/seedCli.js",
    "test": "vitest run"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.60.0",
    "bcryptjs": "^2.4.3",
    "clsx": "^2.1.1",
    "connect-pg-simple": "^10.0.0",
    "date-fns": "^4.4.0",
    "drizzle-orm": "0.45.2",
    "express": "^4.21.1",
    "express-session": "^1.18.1",
    "lucide-react": "^1.24.0",
    "mermaid": "^11.16.0",
    "nanoid": "^5.0.9",
    "otplib": "^12.0.1",
    "pg": "^8.13.1",
    "qrcode": "^1.5.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0",
    "rehype-slug": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.6.0",
    "wouter": "^3.3.5",
    "yaml": "^2.8.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/connect-pg-simple": "^7.0.3",
    "@types/express": "^4.17.21",
    "@types/express-session": "^1.18.0",
    "@types/node": "^20.16.11",
    "@types/pg": "^8.11.10",
    "@types/qrcode": "^1.5.5",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.1",
    "@types/supertest": "^7.2.0",
    "@vitejs/plugin-react": "^4.3.2",
    "autoprefixer": "^10.4.20",
    "cross-env": "^7.0.3",
    "drizzle-kit": "0.31.10",
    "esbuild": "^0.24.0",
    "postcss": "^8.4.47",
    "supertest": "^7.2.2",
    "tailwindcss": "^3.4.14",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3",
    "vite": "^5.4.9",
    "vitest": "^4.1.10"
  }
}
