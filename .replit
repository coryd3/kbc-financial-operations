modules = ["python-3.12", "bash", "nodejs-20", "postgresql-16"]
[agent]
expertMode = true
stack = "BEST_EFFORT_FALLBACK"

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Church App"

[[workflows.workflow]]
name = "Church App"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd app && npm run dev"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[ports]]
localPort = 5000
externalPort = 80

[deployment]
deploymentTarget = "autoscale"
build = ["bash", "-c", "cd app && npm run build"]
publicDir = "site"
run = ["bash", "-c", "cd app && npm start"]

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 180000
