modules = ["python-3.12", "bash"]
[agent]
expertMode = true
stack = "BEST_EFFORT_FALLBACK"

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Documentation Site"

[[workflows.workflow]]
name = "Documentation Site"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python -m mkdocs serve --dev-addr 0.0.0.0:5000"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[ports]]
localPort = 5000
externalPort = 80

[deployment]
deploymentTarget = "static"
build = ["python", "-m", "mkdocs", "build"]
publicDir = "site"
